        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('orderId', json.data.id);",
                  "    console.log('Order ID saved:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"productName\": \"Classic Blue Jeans\",\n      \"unitPrice\": 1499.99,\n      \"quantity\": 2,\n      \"lineTotal\": 2999.98,\n      \"imageUrl\": \"https://example.com/images/jeans.jpg\"\n    },\n    {\n      \"productId\": 2,\n      \"productName\": \"White Cotton T-Shirt\",\n      \"unitPrice\": 599.00,\n      \"quantity\": 1,\n      \"lineTotal\": 599.00\n    }\n  ],\n  \"shippingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Mumbai\",\n    \"state\": \"MH\",\n    \"postalCode\": \"400001\",\n    \"country\": \"India\",\n    \"phoneNumber\": \"+91-9876543210\"\n  },\n  \"billingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Mumbai\",\n    \"state\": \"MH\",\n    \"postalCode\": \"400001\",\n    \"country\": \"India\"\n  },\n  \"paymentMethod\": \"Credit Card\",\n  \"shippingCost\": 99.00,\n  \"taxAmount\": 359.79,\n  \"notes\": \"Please leave at door\"\n}"
            },
            "url": {
              "raw": "{{orderServiceUrl}}/api/orders",
              "host": [
                "{{orderServiceUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Creates a new order. The test script saves the returned order ID to the `orderId` variable."
          }
        },
        {
          "name": "Get My Orders (paginated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
