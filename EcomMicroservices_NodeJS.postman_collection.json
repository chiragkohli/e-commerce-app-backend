{
  "info": {
    "name": "EcomAssignment - Node.js Microservices",
    "description": "Complete API collection for all 5 Node.js microservices.\n\n**Quick Start:**\n1. Run `POST /api/auth/login` (UserService).\n2. The test script auto-saves the token to the collection variable `token`.\n3. All protected endpoints (Cart, Order) use that token automatically.\n\n**Mock credentials:**\n- john@example.com / password123\n- jane@example.com / securepass456\n- admin@example.com / admin123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "userServiceUrl",
      "value": "http://localhost:5001",
      "type": "string"
    },
    {
      "key": "cartServiceUrl",
      "value": "http://localhost:5002",
      "type": "string"
    },
    {
      "key": "orderServiceUrl",
      "value": "http://localhost:5003",
      "type": "string"
    },
    {
      "key": "productServiceUrl",
      "value": "http://localhost:5004",
      "type": "string"
    },
    {
      "key": "searchServiceUrl",
      "value": "http://localhost:5005",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - UserService (port 5001)",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{userServiceUrl}}/health",
              "host": [
                "{{userServiceUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Returns service health status. No auth required."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token saved:', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{userServiceUrl}}/api/auth/login",
              "host": [
                "{{userServiceUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login with email and password. The test script automatically stores the returned `token` in the `token` collection variable."
          }
        },
        {
          "name": "Login - Jane Smith",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"securepass456\"\n}"
            },
            "url": {
              "raw": "{{userServiceUrl}}/api/auth/login",
              "host": [
                "{{userServiceUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login - Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{userServiceUrl}}/api/auth/login",
              "host": [
                "{{userServiceUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login - Invalid credentials (401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@example.com\",\n  \"password\": \"wrongpass\"\n}"
            },
            "url": {
              "raw": "{{userServiceUrl}}/api/auth/login",
              "host": [
                "{{userServiceUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}"
            },
            "url": {
              "raw": "{{userServiceUrl}}/api/auth/logout",
              "host": [
                "{{userServiceUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Invalidates the current token. Uses the `token` collection variable."
          }
        }
      ]
    },
    {
      "name": "02 - CartService (port 5002)",
      "description": "All endpoints (except /health) require `Authorization: Bearer {{token}}`.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{cartServiceUrl}}/health",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Health Check (route)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{cartServiceUrl}}/api/cart/health",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "health"
              ]
            }
          }
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{cartServiceUrl}}/api/cart",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "api",
                "cart"
              ]
            },
            "description": "Returns the authenticated user's cart. Returns 404 if cart doesn't exist yet."
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"productName\": \"Classic Blue Jeans\",\n  \"price\": 1499.99,\n  \"quantity\": 2,\n  \"image\": \"https://example.com/images/jeans.jpg\"\n}"
            },
            "url": {
              "raw": "{{cartServiceUrl}}/api/cart/add",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "add"
              ]
            },
            "description": "Adds an item to the cart. If the product already exists, quantity is incremented."
          }
        },
        {
          "name": "Add Another Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 2,\n  \"productName\": \"White Cotton T-Shirt\",\n  \"price\": 599.00,\n  \"quantity\": 1,\n  \"image\": \"https://example.com/images/tshirt.jpg\"\n}"
            },
            "url": {
              "raw": "{{cartServiceUrl}}/api/cart/add",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "add"
              ]
            }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 2\n}"
            },
            "url": {
              "raw": "{{cartServiceUrl}}/api/cart/remove",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "remove"
              ]
            },
            "description": "Removes the item with the given productId. Deletes the cart document if no items remain."
          }
        },
        {
          "name": "Merge Cart (guest → user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": 10,\n      \"productName\": \"Running Shoes\",\n      \"price\": 3499.00,\n      \"quantity\": 1,\n      \"image\": \"https://example.com/images/shoes.jpg\"\n    },\n    {\n      \"productId\": 11,\n      \"productName\": \"Sports Cap\",\n      \"price\": 299.00,\n      \"quantity\": 3\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{cartServiceUrl}}/api/cart/merge",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "merge"
              ]
            },
            "description": "Replaces the user's cart with the provided guest items (used when a guest logs in). Returns merged cart + item count."
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{cartServiceUrl}}/api/cart/clear",
              "host": [
                "{{cartServiceUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "clear"
              ]
            },
            "description": "Deletes the entire cart for the authenticated user."
          }
        }
      ]
    },
